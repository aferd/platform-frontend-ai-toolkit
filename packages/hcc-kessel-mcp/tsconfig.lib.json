{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": false,
    "types": ["node"],
    "module": "commonjs",
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts"],
  "references": [],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/test-setup.ts",
    "src/**/__tests__/**/*",
    "src/**/mocks/**/*"
  ]
}
